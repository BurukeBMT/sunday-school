{
  "entities": {
    "User": {
      "title": "User",
      "description": "System admin or super admin",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "admin"] },
        "name": { "type": "string" },
        "assignedCourses": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Sunday School student",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Custom ID like ፍ/ሃ/ሰ/ት/00001" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "department": { "type": "string" },
        "qrToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "phone", "department", "qrToken"]
    },
    "Course": {
      "title": "Course",
      "description": "Sunday School course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "department": { "type": "string" },
        "schedule": { "type": "string" },
        "adminIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "department"]
    },
    "AttendanceLog": {
      "title": "AttendanceLog",
      "description": "Record of student attendance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "department": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["studentId", "courseId", "date", "time", "adminId"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course definitions"
    },
    "/attendance_logs/{logId}": {
      "schema": "AttendanceLog",
      "description": "Attendance logs"
    }
  }
}
